#!/bin/bash
# Sets up three network namespaces for FSS project testing:
# ns_client, ns_mitm, ns_server.
#
# The submitted system does not require any trusted code to run in ns_mitm.
# The middle namespace only forwards packets so an evaluator can observe or
# attack traffic from the network path without changing the client/server code.

set -e

# Clean up existing namespaces if present
for ns in ns_client ns_mitm ns_server; do
    ip netns del $ns 2>/dev/null || true
done

# Create namespaces
ip netns add ns_client
ip netns add ns_mitm
ip netns add ns_server

# Create veth pairs
ip link add veth_c type veth peer name veth_cm
ip link add veth_ms type veth peer name veth_sm

# Move interfaces to namespaces
ip link set veth_c netns ns_client
ip link set veth_cm netns ns_mitm
ip link set veth_ms netns ns_mitm
ip link set veth_sm netns ns_server

# Configure client side
ip netns exec ns_client ip addr add 10.0.1.2/24 dev veth_c
ip netns exec ns_client ip link set veth_c up
ip netns exec ns_client ip link set lo up
ip netns exec ns_client ip route add default via 10.0.1.1

# Configure mitm side
ip netns exec ns_mitm ip addr add 10.0.1.1/24 dev veth_cm
ip netns exec ns_mitm ip addr add 10.0.8.1/24 dev veth_ms
ip netns exec ns_mitm ip link set veth_cm up
ip netns exec ns_mitm ip link set veth_ms up
ip netns exec ns_mitm ip link set lo up
ip netns exec ns_mitm sysctl -w net.ipv4.ip_forward=1 > /dev/null
ip netns exec ns_mitm sysctl -w net.ipv4.conf.all.route_localnet=1 > /dev/null

# Configure server side
ip netns exec ns_server ip addr add 10.0.8.2/24 dev veth_sm
ip netns exec ns_server ip link set veth_sm up
ip netns exec ns_server ip link set lo up
ip netns exec ns_server ip route add default via 10.0.8.1

echo "[setup_net] network namespaces ready"
echo "  ns_client: 10.0.1.2"
echo "  ns_mitm:   10.0.1.1 / 10.0.8.1"
echo "  ns_server: 10.0.8.2"
echo "  ns_mitm is a router only; no MITM program is required by the system"
