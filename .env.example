# Demo configuration for the class environment.
# Copy this file to .env for local testing if you add environment loading.
# Do not commit real secrets, production keys, private credentials, or private keys.

# Client/server network settings used by the provided namespace setup.
SERVER_HOST=10.0.8.2
SERVER_PORT=9001

# Current source-code defaults in client.py/server.py if no env loading is added.
SOURCE_DEFAULT_SERVER_HOST=10.0.8.2
SOURCE_DEFAULT_SERVER_PORT=9001

# Client trust anchor.
CA_CERT=ca_cert.pem

# Server certificate and demo-only server private key filenames.
SERVER_CERT=server_cert.pem
SERVER_KEY=server_key.pem

# Server filesystem and logging settings.
STORAGE_DIR=server_storage
SECURITY_LOG=server_security.log

# MITM listener defaults used by mitm_root/home/mitm/mitm.py.
MITM_LISTEN_HOST=0.0.0.0
MITM_LISTEN_PORT=15000

# Protocol/resource limits currently hardcoded in the class implementation.
MAX_MESSAGE_BYTES=10485760
NONCE_WINDOW_SECONDS=60
RATE_WINDOW_SECONDS=60
RATE_MAX_ATTEMPTS=10

# Marker for scripts or local wrappers that want to distinguish demo use.
CLASS_DEMO_MODE=true
